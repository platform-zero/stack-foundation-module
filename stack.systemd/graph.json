{
  "unitPrefix": "webservices",
  "defaultTarget": {
    "name": "webservices.target",
    "description": "Authenticated Web Services platform stack",
    "install": true,
    "includeUnitsFromNonOnDemandDomains": false,
    "wantsTargets": [
      "webservices-core.target",
      "webservices-observability.target",
      "webservices-inference.target",
      "webservices-pipeline.target",
      "webservices-apps.target"
    ]
  },
  "auxiliaryTargets": [
    {
      "name": "webservices-core.target",
      "description": "Core platform services, edge, identity, and stateful backends",
      "services": [
        "caddy",
        "docker-socket-lifecycle-proxy",
        "docker-socket-controller-proxy",
        "docker-socket-proxy",
        "docker-vm-controller-proxy",
        "docker-vm-socket-proxy",
        "isolated-docker-vm-tunnel",
        "keycloak-bootstrap",
        "keycloak",
        "keycloak-configure",
        "keycloak-auth-gateway",
        "mariadb",
        "memcached",
        "onboarding",
        "postgres",
        "postgres-ssd",
        "postgres-ssd-bootstrap",
        "qdrant",
        "valkey",
        "volume-init"
      ]
    },
    {
      "name": "webservices-observability.target",
      "description": "Monitoring, logging, and container observability",
      "afterTargets": [
        "webservices-core.target"
      ],
      "services": [
        "alertmanager",
        "alloy",
        "autoheal",
        "cadvisor",
        "crowdsec",
        "docker-health-exporter",
        "dozzle",
        "grafana",
        "loki",
        "node-exporter",
        "prometheus",
        "watchtower"
      ]
    },
    {
      "name": "webservices-inference.target",
      "description": "Embedding inference backend",
      "afterTargets": [
        "webservices-core.target"
      ],
      "services": [
        "embedding-gpu"
      ]
    },
    {
      "name": "webservices-pipeline.target",
      "description": "Search and publication services",
      "afterTargets": [
        "webservices-core.target",
        "webservices-inference.target"
      ],
      "services": [
        "airflow-init",
        "airflow-webserver",
        "airflow-scheduler",
        "nats",
        "opensearch",
        "qdrant",
        "embedding-gpu",
        "ingestion-runner"
      ]
    },
    {
      "name": "webservices-apps.target",
      "description": "User-facing collaboration and application services",
      "afterTargets": [
        "webservices-core.target"
      ],
      "domains": [
        "mastodon-runtime",
        "vaultwarden-stack"
      ],
      "services": [
        "bookstack",
        "bookstack-procedural-docs",
        "donetick",
        "element",
        "erpnext-configurator",
        "erpnext-bootstrap",
        "erpnext-backend",
        "erpnext-websocket",
        "erpnext-queue-short",
        "erpnext-queue-long",
        "erpnext-scheduler",
        "erpnext",
        "forgejo",
        "forgejo-runner",
        "homeassistant",
        "portal",
        "jellyfin",
        "jupyterhub",
        "kopia",
        "livekit",
        "mailserver",
        "matrix-authentication-service-db",
        "matrix-authentication-service-keys",
        "matrix-authentication-service",
        "matrix-rtc-auth",
        "mastodon-init",
        "ntfy",
        "onlyoffice",
        "planka",
        "seafile",
        "sogo",
        "synapse-permissions",
        "synapse",
        "synapse-room-bootstrap",
        "workspace-provisioner",
        "chatgpt-connector",
        "progression"
      ]
    }
  ],
  "lifecycleDomains": [
    {
      "name": "docker-vm-proxy",
      "services": [
        "isolated-docker-vm-tunnel",
        "docker-vm-socket-proxy"
      ]
    },
    {
      "name": "vaultwarden-stack",
      "services": [
        "vaultwarden",
        "vaultwarden-maintenance"
      ]
    },
    {
      "name": "mastodon-runtime",
      "services": [
        "mastodon-web",
        "mastodon-streaming",
        "mastodon-sidekiq",
        "mastodon-recommendation-seeder"
      ]
    }
  ],
  "excludedServices": [
    "homepage",
    "jellyfin-profile-proxy",
    "jupyter-notebook-build"
  ],
  "onDemandServices": [],
  "onDemandDomains": []
}
